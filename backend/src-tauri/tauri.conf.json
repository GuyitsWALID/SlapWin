{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "SlapMAC",
  "version": "0.1.0",
  "identifier": "com.slapmac.app",
  "build": {
    "frontendDist": "../src-frontend",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "title": "SlapMAC",
        "width": 720,
        "height": 480,
        "resizable": true,
        "center": true,
        "decorations": false,
        "transparent": true,
        "minWidth": 640,
        "minHeight": 420,
        "visible": true
      }
    ],
    "security": {
      "csp": "default-src 'self' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-eval'; img-src 'self' data:; font-src 'self'; connect-src 'self' http://localhost:*"
    }
  },
  "bundle": {
    "active": true,
    "category": "Utility",
    "shortDescription": "SlapMAC - The Windows Utility",
    "longDescription": "A lightweight Windows utility for your productivity needs.",
    "copyright": "Copyright (c) 2026",
    "publisher": "SlapMAC",
    "licenseFile": "../LICENSE",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "webviewInstallMode": {
        "type": "silent"
      },
      "nsis": {
        "languages": ["English"],
        "installMode": "perUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {}
}
